[user]
    name = {{ git_user_name }}
    email = {{ git_user_email }}

[init]
    defaultBranch = {{ git_default_branch }}

[pull]
    rebase = {{ git_pull_rebase | lower }}

[fetch]
    prune = {{ git_fetch_prune | lower }}

[core]
    editor = {{ git_editor }}
    excludesfile = ~/.gitignore_global

[color]
    ui = auto

[push]
    autoSetupRemote = true
